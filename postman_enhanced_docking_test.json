		{
			"name": "05. Task Status Monitoring",
			"item": [
				{
					"name": "5.1 检查默认任务状态",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('状态查询成功', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    console.log('📊 任务状态:', responseJson.status);",
									"    console.log('⏰ 创建时间:', responseJson.created_at);",
									"    if (responseJson.finished_at) {",
									"        console.log('✅ 完成时间:', responseJson.finished_at);",
									"    }",
									"} else {",
									"    console.log('❌ 状态查询失败:', pm.response.text());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/tasks/{{default_task_id}}",
							"host": ["{{base_url}}"],
							"path": ["tasks", "{{default_task_id}}"]
						}
					}
				},
				{
					"name": "5.2 列出所有任务",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('任务列表获取成功', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    const tasks = pm.response.json();",
									"    console.log('📋 总任务数:', tasks.length);",
									"    ",
									"    tasks.forEach((task, index) => {",
									"        console.log(`${index + 1}. ${task.task_type} - ${task.status} (${task.id})`);",
									"    });",
									"    ",
									"    // 查找已完成的docking任务",
									"    const finishedDockingTask = tasks.find(t => t.task_type === 'docking' && t.status === 'finished');",
									"    if (finishedDockingTask) {",
									"        pm.collectionVariables.set('finished_docking_task_id', finishedDockingTask.id);",
									"        console.log('🎯 找到已完成的docking任务:', finishedDockingTask.id);",
									"    }",
									"} else {",
									"    console.log('❌ 任务列表获取失败:', pm.response.text());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/tasks/",
							"host": ["{{base_url}}"],
							"path": ["tasks", ""]
						}
					}
				}
			]
		},
		{
			"name": "06. Results Retrieval",
			"item": [
				{
					"name": "6.1 获取对接结果",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const results = pm.response.json();",
									"    console.log('🎯 对接结果数量:', results.length);",
									"    ",
									"    if (results.length > 0) {",
									"        const firstResult = results[0];",
									"        pm.collectionVariables.set('sdf_filename', firstResult.file);",
									"        console.log('📁 SDF文件名:', firstResult.file);",
									"        console.log('💯 对接得分:', firstResult.score);",
									"        console.log('🧬 SMILES:', firstResult.smiles);",
									"        console.log('🔬 蛋白质路径:', firstResult.protein_path);",
									"    }",
									"} else if (pm.response.code === 202) {",
									"    console.log('⏳ 任务仍在处理中...');",
									"} else {",
									"    console.log('❌ 获取结果失败:', pm.response.text());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
