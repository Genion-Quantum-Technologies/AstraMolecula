{
	"info": {
		"_postman_id": "enhanced-docking-test-2025",
		"name": "Enhanced Docking API - Complete Test Suite",
		"description": "完整的分子对接API测试集合，包含详细的错误处理和验证测试",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "01. Authentication",
			"item": [
				{
					"name": "1.1 登录获取Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('登录成功', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    pm.collectionVariables.set('access_token', responseJson.access_token);",
									"    console.log('✅ Token保存成功:', responseJson.access_token.substring(0, 20) + '...');",
									"} else {",
									"    console.log('❌ 登录失败:', pm.response.text());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin#2024\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						}
					}
				}
			]
		},
		{
			"name": "02. File Upload Tests",
			"item": [
				{
					"name": "2.1 上传蛋白质文件（有效）",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('文件上传成功', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    console.log('✅ 文件上传成功:', responseJson);",
									"} else {",
									"    console.log('❌ 文件上传失败:', pm.response.text());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "files",
									"type": "file",
									"src": "/path/to/your/protein.pdbqt",
									"description": "选择你的蛋白质PDBQT文件"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/upload_pdbqt",
							"host": ["{{base_url}}"],
							"path": ["upload_pdbqt"]
						}
					}
				},
				{
					"name": "2.2 查看已上传文件",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('获取文件列表成功', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    const files = pm.response.json();",
									"    console.log('📁 已上传文件数量:', files.length);",
									"    ",
									"    // 查找第一个pdbqt文件并保存为变量",
									"    const pdbqtFile = files.find(f => f.filename && f.filename.endsWith('.pdbqt'));",
									"    if (pdbqtFile) {",
									"        pm.collectionVariables.set('uploaded_protein_filename', pdbqtFile.filename);",
									"        console.log('✅ 找到PDBQT文件:', pdbqtFile.filename);",
									"    } else {",
									"        console.log('⚠️  未找到PDBQT文件');",
									"    }",
									"} else {",
									"    console.log('❌ 获取文件列表失败:', pm.response.text());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/users/me/uploads",
							"host": ["{{base_url}}"],
							"path": ["users", "me", "uploads"]
						}
					}
				}
			]
		},
		{
			"name": "03. Docking Validation Tests",
			"item": [
				{
					"name": "3.1 测试无效的receptor_filename（非pdbqt格式）",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('应该返回400错误', function () {",
									"    pm.response.to.have.status(400);",
									"});",
									"",
									"pm.test('错误信息应该包含文件格式要求', function () {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.detail.error).to.eql('invalid_receptor_filename');",
									"    pm.expect(responseJson.detail.message).to.include('.pdbqt格式');",
									"});",
									"",
									"console.log('✅ 文件格式验证测试通过:', pm.response.json());"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"ligands\": [\n    {\n      \"smiles\": \"CCO\",\n      \"title\": \"test_ligand\"\n    }\n  ],\n  \"center_x\": 15.0,\n  \"center_y\": 20.0,\n  \"center_z\": 25.0,\n  \"box_size_x\": 20.0,\n  \"box_size_y\": 25.0,\n  \"box_size_z\": 30.0,\n  \"min_ph\": 7.0,\n  \"max_ph\": 7.4,\n  \"n_jobs\": 2,\n  \"exhaustiveness\": 8,\n  \"n_poses\": 20\n}"
						},
						"url": {
							"raw": "{{base_url}}/docking?receptor_filename=invalid_protein.txt",
							"host": ["{{base_url}}"],
							"path": ["docking"],
							"query": [
								{
									"key": "receptor_filename",
									"value": "invalid_protein.txt"
								}
							]
						}
					}
				},
				{
					"name": "3.2 测试包含非法字符的filename",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('应该返回400错误', function () {",
									"    pm.response.to.have.status(400);",
									"});",
									"",
									"pm.test('错误信息应该提及非法字符', function () {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.detail.error).to.eql('invalid_receptor_filename');",
									"    pm.expect(responseJson.detail.message).to.include('非法字符');",
									"});",
									"",
									"console.log('✅ 非法字符验证测试通过:', pm.response.json());"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"ligands\": [\n    {\n      \"smiles\": \"CCO\",\n      \"title\": \"test_ligand\"\n    }\n  ],\n  \"center_x\": 15.0,\n  \"center_y\": 20.0,\n  \"center_z\": 25.0,\n  \"box_size_x\": 20.0,\n  \"box_size_y\": 25.0,\n  \"box_size_z\": 30.0,\n  \"min_ph\": 7.0,\n  \"max_ph\": 7.4,\n  \"n_jobs\": 2,\n  \"exhaustiveness\": 8,\n  \"n_poses\": 20\n}"
						},
						"url": {
							"raw": "{{base_url}}/docking?receptor_filename=../../../etc/passwd.pdbqt",
							"host": ["{{base_url}}"],
							"path": ["docking"],
							"query": [
								{
									"key": "receptor_filename",
									"value": "../../../etc/passwd.pdbqt"
								}
							]
						}
					}
				},
				{
					"name": "3.3 测试不存在的receptor_filename",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('应该返回404错误', function () {",
									"    pm.response.to.have.status(404);",
									"});",
									"",
									"pm.test('错误信息应该包含可用文件列表', function () {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.detail.error).to.eql('receptor_file_not_found');",
									"    pm.expect(responseJson.detail.details).to.have.property('available_pdbqt_files');",
									"});",
									"",
									"console.log('✅ 文件不存在验证测试通过:', pm.response.json());"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"ligands\": [\n    {\n      \"smiles\": \"CCO\",\n      \"title\": \"test_ligand\"\n    }\n  ],\n  \"center_x\": 15.0,\n  \"center_y\": 20.0,\n  \"center_z\": 25.0,\n  \"box_size_x\": 20.0,\n  \"box_size_y\": 25.0,\n  \"box_size_z\": 30.0,\n  \"min_ph\": 7.0,\n  \"max_ph\": 7.4,\n  \"n_jobs\": 2,\n  \"exhaustiveness\": 8,\n  \"n_poses\": 20\n}"
						},
						"url": {
							"raw": "{{base_url}}/docking?receptor_filename=nonexistent_protein.pdbqt",
							"host": ["{{base_url}}"],
							"path": ["docking"],
							"query": [
								{
									"key": "receptor_filename",
									"value": "nonexistent_protein.pdbqt"
								}
							]
						}
					}
				}
			]
		},
		{
