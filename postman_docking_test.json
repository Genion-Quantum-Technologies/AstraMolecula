	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// 预请求脚本 - 可以在这里添加动态token获取逻辑",
					"console.log('开始请求:', pm.request.url);"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// 测试脚本",
					"pm.test(\"状态码是 200\", function () {",
					"    pm.response.to.have.status(200);",
					"});",
					"",
					"pm.test(\"响应包含 task_id\", function () {",
					"    var jsonData = pm.response.json();",
					"    pm.expect(jsonData).to.have.property('task_id');",
					"    pm.expect(jsonData.task_id).to.be.a('string');",
					"});",
					"",
					"pm.test(\"响应时间小于 5 秒\", function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(5000);",
					"});",
					"",
					"// 保存task_id到环境变量",
					"if (pm.response.code === 200) {",
					"    var jsonData = pm.response.json();",
					"    if (jsonData.task_id) {",
					"        pm.environment.set(\"last_task_id\", jsonData.task_id);",
					"        console.log('任务ID已保存:', jsonData.task_id);",
					"    }",
					"}"
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://3.133.131.124:8000",
			"type": "string"
		},
		{
			"key": "auth_token",
			"value": "YOUR_TOKEN_HERE",
			"type": "string"
		}
	]
