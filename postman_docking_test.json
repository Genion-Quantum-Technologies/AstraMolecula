				"body": {
					"mode": "raw",
					"raw": "{\n  \"ligands\": [\n    {\n      \"smiles\": \"C=CCNC(=O)c1ccc(O)cc1\",\n      \"title\": \"Test_Ligand_1\"\n    },\n    {\n      \"smiles\": \"CC(C)CC1=CC=C(C=C1)C(C)C(=O)O\",\n      \"title\": \"Test_Ligand_2\"\n    },\n    {\n      \"smiles\": \"CC1=C(C(=CC=C1)C(=O)O)CC2=CC=C(C=C2)CC3C(=O)NC(=O)S3\",\n      \"title\": \"Test_Ligand_3\"\n    }\n  ],\n  \"min_ph\": 6.0,\n  \"max_ph\": 8.0,\n  \"n_jobs\": 4\n}"
				},
				"url": {
					"raw": "http://3.133.131.124:8000/docking?receptor_filename=protein_7UDP.pdbqt",
					"protocol": "http",
					"host": [
						"3.133.131.124"
					],
					"port": "8000",
					"path": [
						"docking"
					],
					"query": [
						{
							"key": "receptor_filename",
							"value": "protein_7UDP.pdbqt",
							"description": "受体文件名"
						}
					]
				},
				"description": "使用默认受体文件进行分子对接测试"
			},
			"response": []
